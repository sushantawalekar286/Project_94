# Copy this file to .env and fill in real values. NEVER commit secrets.

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/digital-waiter

# Auth
JWT_SECRET=replace_with_a_secure_random_string_min_32_chars

# Client URL (the frontend origin)
CLIENT_URL=http://localhost:5173

# Optional Cloudinary
#CLOUDINARY_CLOUD_NAME=
#CLOUDINARY_API_KEY=
#CLOUDINARY_API_SECRET=
